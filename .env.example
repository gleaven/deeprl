# ───────────────────────────────────────────────────────────────────
# DeepRL has no external API dependencies — training runs locally on
# your GPU. Configure host port mappings and tuning knobs only.
# ───────────────────────────────────────────────────────────────────

# Number of parallel training environments. 256 is the default; lower
# for a smaller GPU.
N_ENVS=256

# Training speed multiplier (1 = real time visualisation).
TRAINING_SPEED=1

# ───────────────────────────────────────────────────────────────────
# Host port mappings.
# ───────────────────────────────────────────────────────────────────
APP_PORT=8080
REDIS_HOST_PORT=6379

# ───────────────────────────────────────────────────────────────────
# BYO overrides — uncomment + set + start with the byo override.
#   docker compose -f docker-compose.yml -f docker-compose.byo.yml up -d
# ───────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis.example.com:6379/10

# ───────────────────────────────────────────────────────────────────
# Optional HTTPS reverse proxy (--profile proxy).
# ───────────────────────────────────────────────────────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
